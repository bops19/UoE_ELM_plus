# Core
OPENAI_API_KEY=
API_KEY=
ELMPLUS_API_KEY=
APP_ENV=development
FLASK_ENV=development

# Runtime storage
ELMPLUS_RUNTIME_DIR=
XDG_DATA_HOME=

# Request sizing / timeout
REQUEST_BODY_MAX_BYTES=62914560
JSON_BODY_MAX_BYTES=1048576
OPENAI_TIMEOUT_SEC=90

# Process limits
APP_MIN_NOFILE_SOFT=4096

# Rate limit trust + cleanup
RATE_LIMIT_TRUSTED_PROXIES=
RATE_LIMIT_CLEANUP_INTERVAL_SEC=120
RATE_LIMIT_CLEANUP_MAX_ROWS=5000

# Session retention
SESSION_ARCHIVE_AFTER_DAYS=7
SESSION_DELETE_ARCHIVED_AFTER_DAYS=60

# Deep research tools
DEEP_RESEARCH_VECTOR_STORE_IDS=
DEEP_RESEARCH_MCP_SERVER_URL=
DEEP_RESEARCH_MCP_SERVER_LABEL=deep_research_mcp
DEEP_RESEARCH_MCP_PROFILES_JSON=

# Monitoring
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
